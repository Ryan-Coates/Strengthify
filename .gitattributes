# Enforce Unix line endings for shell scripts so they work inside Docker (Linux)
gradlew     text eol=lf
*.sh        text eol=lf
*.kts       text eol=lf
*.kt        text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.pro       text eol=lf
